# ============================================================
# ACE-Step 1.5 XL Docker Runtime
# Deterministic, host-mapped, ComfyUI-style persistence
# ============================================================

PROJECT_NAME=ace-step-xl
SERVICE_NAME=ace-step-xl

# Informational only — not read by the script or compose.
# ACE_IMAGE_REF is the single source of truth for the image to use.
ACE_IMAGE=valyriantech/ace-step-1.5-xl
ACE_TAG=14042026

# Optional stronger pin after you verify full digest locally:
# ACE_IMAGE_REF=valyriantech/ace-step-1.5-xl@sha256:<FULL_DIGEST>
ACE_IMAGE_REF=valyriantech/ace-step-1.5-xl:14042026

# Host bind root
ACE_DATA_DIR=./data

# Host data dir ownership — used by run-ace.sh to chown ./data on the host.
# The container itself runs as root (required by upstream image).
HOST_UID=1000
HOST_GID=1000

# Network
ACE_HOST=0.0.0.0
ACE_PORT=8000

# gpu or cpu
ACE_PROFILE=gpu

# App/device config
# cuda for NVIDIA, cpu for CPU mode.
ACESTEP_DEVICE=cuda

# Persistence inside container
# Output dir — where generated audio is written
ACESTEP_OUTPUT_DIR=/app/outputs

# Model paths — defaults point to the checkpoints baked into the image.
# Override to a host-mounted path only if you supply pre-downloaded models.
ACESTEP_CONFIG_PATH=/app/checkpoints/acestep-v15-xl-base
ACESTEP_LM_MODEL_PATH=/app/checkpoints/acestep-5Hz-lm-1.7B
ACESTEP_LM_BACKEND=pt

# Standard cache directories (survive image upgrades)
HF_HOME=/app/hf-cache
TORCH_HOME=/app/torch-cache
XDG_CACHE_HOME=/app/cache

# NVIDIA config
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Runtime behavior
RESTART_POLICY=unless-stopped
SHM_SIZE=8g

# Logging
LOG_MAX_SIZE=100m
LOG_MAX_FILE=5
LOG_TAIL=200

# Security/convenience
TZ=Asia/Jakarta